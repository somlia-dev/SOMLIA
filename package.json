{
  "name": "somlia-landing-page",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/dashboard"
  ],
  "engines": {
    "node": ">=24.15.0 <25"
  },
  "scripts": {
    "dev": "vite",
    "dev:landing": "vite",
    "dev:dashboard": "npm --workspace @somlia/dashboard start",
    "build": "npm run build:landing",
    "build:landing": "tsc -b && vite build && npm run verify:font:dist",
    "build:dashboard": "npm --workspace @somlia/dashboard run build",
    "build:all": "npm run build:landing && npm run build:dashboard",
    "preview": "vite preview",
    "test": "npm run verify:font && vitest run",
    "test:landing": "npm run verify:font && vitest run",
    "test:dashboard": "npm --workspace @somlia/dashboard test -- --watch=false",
    "test:all": "npm run test:landing && npm run test:dashboard",
    "test:watch": "vitest",
    "verify:font": "node scripts/verify-font-assets.mjs",
    "verify:font:dist": "node scripts/verify-font-assets.mjs --dist"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "@vercel/analytics": "^2.0.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.8"
  }
}
