# Dashboard environment variables (documented names only).
# Real values belong in local untracked files or deployment provider settings.

# Supabase (public dashboard client values only)
DASHBOARD_SUPABASE_URL=https://your-project.supabase.co
DASHBOARD_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Custom backend API boundary (server-mediated operations)
DASHBOARD_API_BASE_URL=

# Auth redirect target after successful sign-in
DASHBOARD_AUTH_REDIRECT_URL=http://localhost:4200/dashboard/tasks

# Feature flags
DASHBOARD_AUTH_ENABLED=false
DASHBOARD_GOOGLE_ENABLED=false
