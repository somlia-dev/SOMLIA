# Supabase platform values (documented names only).
# On Supabase Edge Functions these are injected automatically.
# For local/other runtimes, copy into an untracked local env file.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# Waitlist Edge Function secrets (server-only)
LOOPS_API_KEY=your-loops-api-key
WAITLIST_WEBHOOK_SECRET=use-a-long-random-secret
LOOPS_WAITLIST_EVENT_NAME=waitlistJoined
